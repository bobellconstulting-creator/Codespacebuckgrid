# WildLogic v2 Environment Variables
GOOGLE_AI_KEY=                    # Gemini 2.5 Flash (primary Tony AI)
NEXT_PUBLIC_MAPBOX_TOKEN=         # Mapbox GL JS (satellite map)
KV_REST_API_URL=                  # Upstash Redis (rate limiting + entitlements)
KV_REST_API_TOKEN=                # Upstash Redis auth token
STRIPE_SECRET_KEY=                # Stripe server-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
GROQ_API_KEY=                     # Groq (free text fallback)
ANTHROPIC_API_KEY=                # Paid fallback (requires ENABLE_PAID_FALLBACK=1)
ENABLE_PAID_FALLBACK=             # Set to "1" to enable Haiku/Sonnet fallback
NEXT_PUBLIC_SUPABASE_URL=         # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # Supabase anonymous key
OLLAMA_BASE_URL=                  # Optional: http://localhost:11434 for local Hermes
OLLAMA_MODEL=hermes3              # Default Ollama model name
